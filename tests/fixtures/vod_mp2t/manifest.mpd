<?xml version="1.0" encoding="UTF-8"?>
<MPD xmlns="urn:mpeg:dash:schema:mpd:2011"
     type="static"
     mediaPresentationDuration="PT8S"
     minBufferTime="PT2S"
     profiles="urn:mpeg:dash:profile:mp2t-simple:2011">
  <Period>
    <AdaptationSet mimeType="video/mp2t" contentType="video" segmentAlignment="true">
      <SegmentTemplate timescale="1000" duration="4000"
                       media="seg-$Number$.$Ext$"
                       startNumber="1"/>
      <Representation id="1" bandwidth="1000000" codecs="avc1.4d401f" width="640" height="360"/>
    </AdaptationSet>
  </Period>
</MPD>
